# The MCP loads ~/Code/easyPCR/.env by default. Override with NOTIFY_ENV_FILE.
# These are the keys it reads:

RETELL_API_KEY=          # already in easyPCR/.env
RETELL_AGENT_ID=         # your Retell agent id (prompt must contain {{your_question}})
RETELL_FROM_NUMBER=      # a Retell-registered number to call FROM (+1...)
MY_PHONE_NUMBER=         # the number to call/text you at (+1...)
IMESSAGE_HANDLE=         # optional; defaults to MY_PHONE_NUMBER. phone or Apple ID email
NGROK_AUTHTOKEN=         # from dashboard.ngrok.com

# Optional tuning:
# NOTIFY_PORT=8787
# CALL_TIMEOUT_MS=300000
# NOTIFY_ENV_FILE=/absolute/path/to/.env
